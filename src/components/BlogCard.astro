---
import { formatDate } from "../utils/formatDate";
import Tag from "./Tag.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags } = Astro.props;
---

<a
  href={`/blog/${slug}`}
  class="blog-card group block rounded-xl border border-gray-200 bg-white p-6 transition-all duration-300 hover:border-primary-300 hover:shadow-lg dark:border-gray-700 dark:bg-gray-800 dark:hover:border-primary-600"
>
  <div class="blog-card__meta mb-3 flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400">
    <time datetime={date.toISOString()}>{formatDate(date)}</time>
  </div>
  <div class="blog-card__body">
    <h3 class="blog-card__title mb-2 text-xl font-semibold text-gray-900 transition-colors group-hover:text-primary-600 dark:text-gray-100 dark:group-hover:text-primary-400">
      {title}
    </h3>
    <p class="blog-card__description mb-4 line-clamp-2 text-gray-600 dark:text-gray-400">{description}</p>
  </div>
  {tags && (
    <div class="blog-card__tags flex flex-wrap gap-2">
      {tags.slice(0, 3).map((tag) => <Tag name={tag} size="sm" asLink={false} />)}
    </div>
  )}
</a>
