---
import BaseLayout from "./BaseLayout.astro";
import { formatDate } from "../utils/formatDate";
import SideArrowNavigation from "../components/SideArrowNavigation.astro";
import SwipeNavigator from "../components/SwipeNavigator.astro";
import type { AdjacentNavigation } from "../utils/contentNavigation";

interface Props {
  frontmatter: {
    title: string;
    date: Date;
    topic?: string;
  };
  navigation?: AdjacentNavigation;
}

const { frontmatter, navigation } = Astro.props;
---

<BaseLayout title={frontmatter.title} type="article" showScrollProgress={true}>
  <SideArrowNavigation
    itemLabel="note"
    previous={navigation?.previous}
    next={navigation?.next}
  />
  <article class="max-w-3xl mx-auto px-4 py-16" data-swipe-nav-root style="touch-action: pan-y;">
    <header class="mb-8">
      <div class="flex items-center gap-4 text-sm text-gray-500 dark:text-gray-400 mb-4">
        <time datetime={frontmatter.date.toISOString()}>
          {formatDate(frontmatter.date)}
        </time>
        {
          frontmatter.topic && (
            <>
              <span>&middot;</span>
              <a
                href={`/notes?topic=${encodeURIComponent(frontmatter.topic)}`}
                class="text-primary-600 dark:text-primary-400 hover:underline"
              >
                {frontmatter.topic}
              </a>
            </>
          )
        }
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white">
        {frontmatter.title}
      </h1>
    </header>
    <div
      class="prose prose-gray dark:prose-invert max-w-none prose-headings:font-semibold prose-a:text-primary-600 dark:prose-a:text-primary-400 prose-code:text-primary-700 dark:prose-code:text-primary-300 prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded"
    >
      <slot />
    </div>
    <SwipeNavigator
      itemLabel="note"
      previous={navigation?.previous}
      next={navigation?.next}
    />
  </article>
</BaseLayout>
